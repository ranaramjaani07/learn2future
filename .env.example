# ============================================================
# Learn 2 Future — Environment Variables
# Copy to .env.local for local dev, set in Vercel Dashboard for production
# ============================================================

# ── RAZORPAY (SERVER-SIDE ONLY — NEVER expose to frontend) ──
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# DEVELOPMENT = allow sandbox simulation fallback
# PRODUCTION  = require real Razorpay keys, no simulation
PAYMENT_ENV=DEVELOPMENT

# ── FIREBASE (server-side REST API access) ───────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_FIRESTORE_DATABASE_ID=(default)
FIREBASE_API_KEY=your-firebase-web-api-key

# ── VITE FRONTEND (public — safe to expose) ─────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_DATABASE_ID=(default)
VITE_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXXXXXX

# ============================================================
# SECURITY: RAZORPAY_KEY_SECRET must ONLY be a Vercel env var
# NEVER put it in firebase, .env files committed to git, or frontend
# ============================================================
