{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer-when-downgrade"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/ixfm9d83np3zq7qhq7py8uzp463wxi",
      "destination": "/ixfm9d83np3zq7qhq7py8uzp463wxi.html"
    },
    {
      "source": "/ixfm9d83np3zq7qhq7py8uzp463wxi/",
      "destination": "/ixfm9d83np3zq7qhq7py8uzp463wxi.html"
    },
    {
      "source": "/google6137fd0ecd2db4b0",
      "destination": "/google6137fd0ecd2db4b0.html"
    },
    {
      "source": "/google6137fd0ecd2db4b0/",
      "destination": "/google6137fd0ecd2db4b0.html"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/sitemap-static.xml",
      "destination": "/api/sitemap?type=static"
    },
    {
      "source": "/sitemap-courses.xml",
      "destination": "/api/sitemap?type=courses"
    },
    {
      "source": "/sitemap-blogs.xml",
      "destination": "/api/sitemap?type=blogs"
    },
    {
      "source": "/sitemap-categories.xml",
      "destination": "/api/sitemap?type=categories"
    },
    {
      "source": "/sitemap-images.xml",
      "destination": "/api/sitemap?type=images"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/pay/create-order.js": {
      "maxDuration": 30
    },
    "api/pay/verify-payment.js": {
      "maxDuration": 30
    },
    "api/pay/webhook.js": {
      "maxDuration": 30
    },
    "api/sitemap.js": {
      "maxDuration": 30
    }
  }
}
