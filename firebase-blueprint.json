    "order": {
      "title": "Order Schema",
      "description": "Registration of a course purchase before status verification",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The full name of the purchaser"
        },
        "buyerName": {
          "type": "string",
          "description": "Mandated buyer name field matching name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The contact email address"
        },
        "telegram": {
          "type": "string",
          "description": "Telegram username for communication"
        },
        "telegramUsername": {
          "type": "string",
          "description": "Mandated telegram username field matching telegram"
        },
        "courseId": {
          "type": "string",
          "description": "Identifier of the purchased course"
        },
        "courseName": {
          "type": "string",
          "description": "Name of the purchased course"
        },
        "proofImage": {
          "type": "string",
          "description": "Base64 encoded string or URL of payment screenshot"
        },
        "screenshotUrl": {
          "type": "string",
          "description": "Legacy reference URL of payment screenshot"
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Verified", "Delivered"],
          "description": "Verification status of the order"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of order creation"
        }
      },
      "required": ["name", "buyerName", "email", "telegram", "telegramUsername", "courseId", "courseName", "proofImage", "screenshotUrl", "status", "createdAt"]
    },
    "contactMessage": {
      "title": "Contact Message Schema",
      "description": "Message submitted by customers via Contact form",
