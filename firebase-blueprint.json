          "type": "string",
          "description": "Google Search Console Verification meta tag value"
        },
        "facebookDomainVerification": {
          "type": "string",
          "description": "Facebook Domain Verification meta tag value"
        }
      },
      "required": []
    },
    "coupon": {
      "title": "Coupon Schema",
      "description": "Discount coupon codes and promotion values configured by administration",
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "Uppercase coupon promotion code (e.g. WELCOME50)"
        },
        "type": {
          "type": "string",
          "enum": ["percentage", "fixed"],
          "description": "Type of calculation deduction applied"
        },
        "value": {
          "type": "number",
          "description": "Percent off value or flat billing reduction sum amount"
        },
        "minOrderValue": {
          "type": "number",
          "description": "Optional minimum order total price required to actuate discount"
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates whether coupon code is active and valid for redeem"
        },
        "expiresAt": {
          "type": "string",
          "description": "Optional custom expiration timestamp locator string"
        },
        "usedCount": {
          "type": "number",
          "description": "Number of times this coupon has been used and approved"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the coupon was created"
        }
      },
      "required": ["code", "type", "value", "isActive", "createdAt"]
    },
