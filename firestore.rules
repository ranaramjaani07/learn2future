rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── DEFAULT DENY ALL ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── HELPER FUNCTIONS ─────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && (
          request.auth.token.email.lower() == "digitalcoursesbay@gmail.com"
        )) ||
        request.auth.uid == "7FLbcBGlHAPKxnFc8V0ypY3DPKq2" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email != null && (
          exists(/databases/$(database)/documents/adminUsers/$(request.auth.token.email.lower())) ||
          exists(/databases/$(database)/documents/adminUsers/$(request.auth.token.email))
        ))
      );
    }

    // Vercel REST API calls have NO Firebase Auth token → request.auth IS null
    function isServerCall() {
      return request.auth == null;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ── SCHEMA VALIDATORS ────────────────────────────────────────

    function isValidCourse(data) {
      return data.title is string && data.title.size() <= 150
        && data.price is number && data.price >= 0
        && data.description is string && data.description.size() <= 50000;
    }

    function isValidContactMessage(data) {
      return data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 120
        && data.message is string && data.message.size() <= 3000;
    }

    function isValidReview(data) {
      return data.userId is string
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.reviewText is string && data.reviewText.size() <= 2000
        && data.verifiedPurchase == true
        && data.status in ['Approved', 'Pending', 'Rejected'];
    }

    function isValidBlog(data) {
      return data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 3000000
        && data.slug is string && data.slug.size() <= 200;
    }

    // RELAXED user validator - only checks critical fields
    // Strict validation was causing write failures → user doc missing → onboarding loop!
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 150
        && data.onboardingCompleted is bool;
    }

    function isValidActivityLog(data) {
      return data.userId is string && data.action is string
        && data.details is string;
    }

    function isValidAffiliateApplication(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.fullName is string && data.email is string
        && data.status in ['pending','approved','rejected','suspended'];
    }

    function isValidPayoutRequest(data) {
      return data.uid is string && data.email is string
        && data.amount is number
        && data.status in ['Pending','Approved','Rejected'];
    }

    function isValidStudentPortfolio(data) {
      return (!('fullName' in data) || (data.fullName is string && data.fullName.size() <= 150))
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 3000));
    }

    function isValidHeroOrbitItem(data) {
      return data.title is string && data.image is string
        && data.link is string && data.enabled is bool;
    }

    // ── COLLECTION RULES ─────────────────────────────────────────

    // 1. COURSES — public read, admin write
    match /courses/{courseId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCourse(incoming());
      allow delete:         if isAdmin();
    }

    // 2. ORDERS
    // Vercel REST API (isServerCall) writes after payment — no auth token
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.email  == request.auth.token.email ||
        isAdmin()
      );
      allow list:           if isAdmin();
      allow create, update: if isServerCall() || isAdmin();
      allow delete:         if isAdmin();
    }

    // 3. CONTACT MESSAGES
    match /contactMessages/{messageId} {
      allow get, list: if isAdmin();
      allow create:    if isValidContactMessage(incoming());
      allow update:    if isAdmin();
      allow delete:    if isAdmin();
    }

    // 4. ADMINS
    match /admins/{adminUid} {
      allow read:                   if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // 5. TESTIMONIALS
    match /testimonials/{testimonialId} {
      allow read:           if true;
      allow create:         if isSignedIn() || isAdmin();
      allow update, delete: if isAdmin();
    }

    // 5.5. REVIEWS
    match /reviews/{reviewId} {
      allow read:   if true;
      allow create: if isSignedIn() && isValidReview(incoming())
        && incoming().userId == request.auth.uid;
      allow update: if (isSignedIn() && existing().userId == request.auth.uid && isValidReview(incoming()))
        || isAdmin();
      allow delete: if (isSignedIn() && existing().userId == request.auth.uid) || isAdmin();
    }

    // 6. SETTINGS
    // paymentGateway: ADMIN ONLY (contains Razorpay secret)
    match /settings/paymentGateway {
      allow read, write: if isAdmin();
    }
    match /settings/tracking {
      allow read:  if true;
      allow write: if isAdmin();
    }
    match /settings/globalSettings {
      allow read:  if true;
      allow write: if isAdmin();
    }
    match /settings/homepageSettings {
      allow read:  if true;
      allow write: if isAdmin();
    }
    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    // 7. BLOGS
    match /blogs/{blogId} {
      allow read:           if true;
      allow create, update: if isAdmin() && isValidBlog(incoming());
      allow delete:         if isAdmin();
    }

    // 8. COUPONS
    // Public read (checkout), admin + server write (usedCount update after payment)
    match /coupons/{code} {
      allow read:           if true;
      allow create, update: if isAdmin() || isServerCall();
      allow delete:         if isAdmin();
    }

    // 9. ADMIN USERS
    match /adminUsers/{emailId} {
      allow get: if isSignedIn() && request.auth.token.email != null && (
        request.auth.token.email.lower() == "digitalcoursesbay@gmail.com" ||
        request.auth.token.email.lower() == emailId.lower() ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
      allow list:   if isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin() && emailId.lower() != "digitalcoursesbay@gmail.com";
    }

    // 10. USERS ← CRITICAL FOR ONBOARDING
    // Read: user reads their own doc → determines if onboarding needed
    // Create: user saves onboarding data for first time
    // Update: user or admin updates profile
    // RELAXED validator (strict validator was causing write failures → onboarding loop!)
    match /users/{userId} {
      allow get:    if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list:   if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId
        && incoming().uid == request.auth.uid
        && isValidUser(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // 11. USER SETTINGS
    match /userSettings/{userId} {
      allow get, list:      if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete:         if isAdmin();
    }

    // 12. USER PROFILES
    match /userProfiles/{userId} {
      allow get, list:      if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete:         if isAdmin();
    }

    // 13. ACTIVITY LOGS
    match /activityLogs/{logId} {
      allow read:           if isAdmin();
      allow create:         if isSignedIn() && isValidActivityLog(incoming());
      allow update, delete: if isAdmin();
    }

    // 14. CART ITEMS
    match /cartItems/{cartItemId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
      allow delete:         if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 15. USER PURCHASES ← FIXED (was causing 403 after Razorpay payment)
    // Vercel verify-payment writes here → isServerCall() = true
    match /userPurchases/{purchaseId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isServerCall() || isAdmin();
      allow delete:         if isAdmin();
    }

    // 16. PAYMENT RECOVERY QUEUE
    match /paymentRecoveryQueue/{id} {
      allow read:           if isAdmin();
      allow create, update: if isServerCall() || isAdmin();
      allow delete:         if isAdmin();
    }

    // 17. PAYMENT LOGS
    match /paymentLogs/{logId} {
      allow read:           if isAdmin();
      allow create, update: if isServerCall() || isAdmin();
      allow delete:         if isAdmin();
    }

    // 18. COURSE SHARES
    match /courseShares/{shareId} {
      allow create: if isSignedIn() || true;
      allow read:   if isAdmin();
      allow update, delete: if isAdmin();
    }

    // 19. COURSE REFERRALS
    match /courseReferrals/{refId} {
      allow create: if isSignedIn() || true;
      allow read:   if isAdmin();
      allow update, delete: if isAdmin();
    }

    // 20. STUDENT PORTFOLIOS
    match /student_portfolios/{uid} {
      allow read:   if true;
      allow create: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    match /student_portfolios/{uid}/cheers/{cheerId} {
      allow read:           if true;
      allow create:         if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // 21. HERO ORBIT ITEMS
    match /heroOrbitItems/{itemId} {
      allow read:           if true;
      allow create, update: if isAdmin() && isValidHeroOrbitItem(incoming());
      allow delete:         if isAdmin();
    }

    // 22. AFFILIATE APPLICATIONS
    // Server updates pendingEarnings after commission → isServerCall()
    match /affiliate_applications/{uid} {
      allow read:   if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list:   if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == uid
        && isValidAffiliateApplication(incoming())
        && incoming().uid == request.auth.uid
        && incoming().status == 'pending';
      allow update: if isAdmin() || isServerCall()
        || (isSignedIn() && request.auth.uid == uid);
      allow delete: if (isSignedIn() && request.auth.uid == uid) || isAdmin();
    }

    // 23. PAYOUT REQUESTS
    match /payout_requests/{payoutId} {
      allow read:           if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow list:           if isAdmin();
      allow create:         if isSignedIn() && isValidPayoutRequest(incoming())
        && incoming().uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 24. AFFILIATE SALES — server writes after every paid order
    match /affiliate_sales/{saleId} {
      allow read:           if isSignedIn() && (resource.data.affiliateUid == request.auth.uid || isAdmin());
      allow list:           if isAdmin();
      allow create, update: if isServerCall() || isAdmin();
      allow delete:         if isAdmin();
    }

    // 25. AFFILIATE ANALYTICS — server syncs after every commission
    match /affiliate_analytics/{affiliateUid} {
      allow read:           if isSignedIn() && (request.auth.uid == affiliateUid || isAdmin());
      allow list:           if isAdmin();
      allow create, update: if isServerCall() || isAdmin();
      allow delete:         if isAdmin();
    }
  }
}
